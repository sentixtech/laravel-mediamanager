{
    "name": "sentix/laravel-mediamanager",
    "description": "A comprehensive media manager package for Laravel",
    "type": "laravel-package",
    "license": "MIT",
    "version": "1.0.1",
    "authors": [
        {
            "name": "Sentix",
            "email": "your-email@example.com"
        }
    ],
    "require": {
        "php": "^8.0|^8.1|^8.2|^8.3|^8.4|^8.5",
        "illuminate/support": "^9.0|^10.0|^11.0|^12.0|^13.0",
        "intervention/image": "^2.7|^3.0"
    },
    "require-dev": {
        "orchestra/testbench": "^7.0|^8.0|^9.0",
        "phpunit/phpunit": "^9.5|^10.0"
    },
    "autoload": {
        "psr-4": {
            "Sentix\\MediaManager\\": "src"
        },
        "files": [
            "src/helpers.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Sentix\\MediaManager\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
           
            "aliases": {
                "Media": "Sentix\\MediaManager\\Facades\\Media"
            }
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
